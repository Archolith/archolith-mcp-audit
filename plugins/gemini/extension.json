{
  "name": "archolith-audit",
  "version": "0.1.0",
  "description": "Live MCP token usage audit",
  "license": "Apache-2.0",
  "repository": "https://github.com/Archolith/archolith-audit-plugin-gemini",
  "hooks": {
    "AfterTool": "hooks/after-tool.js"
  },
  "mcpServers": {
    "archolith-audit": {
      "command": "python",
      "args": ["-m", "archolith_mcp_audit.bootstrap", "mcp", "--agent", "gemini"],
      "env": {
        "MCP_AUDIT_ENABLED": "1",
        "PYTHONPATH": "${GEMINI_PLUGIN_DIR}"
      }
    }
  }
}
