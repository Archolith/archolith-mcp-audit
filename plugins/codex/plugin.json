{
  "name": "archolith-audit",
  "version": "0.1.0",
  "description": "Live MCP token usage audit for Codex sessions.",
  "author": "archolith",
  "homepage": "https://archolith.dev",
  "repository": "https://github.com/Archolith/archolith-audit-plugin-codex",
  "license": "Apache-2.0",
  "mcpServers": {
    "archolith-audit": {
      "command": "python",
      "args": ["-m", "archolith_mcp_audit.bootstrap", "mcp", "--agent", "codex"],
      "env": {
        "MCP_AUDIT_ENABLED": "1",
        "PYTHONPATH": "${CODEX_PLUGIN_DIR}"
      }
    }
  }
}
